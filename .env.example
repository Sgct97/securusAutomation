# =========================================================================
# SECURUS CREDENTIALS (required)
# =========================================================================
SECURUS_PASSWORD=your_password_here

# =========================================================================
# PIPELINE SETTINGS (Linda: adjust these to change daily behavior)
# =========================================================================

# Max outreach messages per day (set to 0 to pause all sending)
DAILY_MESSAGE_LIMIT=25

# How often to scrape for new inmates (in days)
SCRAPE_INTERVAL_DAYS=7

# Which states to include (comma-separated)
STATES_TO_SCRAPE=WA,OK,NY,CA,AR

# =========================================================================
# ADVANCED (usually no need to change)
# =========================================================================
HEADLESS=true
LOG_LEVEL=INFO
SECURUS_ACTION_DELAY=15
DATABASE_URL=sqlite+aiosqlite:///./data/inmates.db
